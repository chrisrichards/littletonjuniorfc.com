{
	"compatibility_date": "2026-05-21",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "littletonjuniorfc",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
	  {
	    "binding": "DB",
	    "database_name": "ljfc-bookings",
	    "database_id": "38d3059f-cb06-45e2-a38b-23641ea1d19d"
	  }
	]
}