---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import CardGrid from '../components/CardGrid.astro';
import Card from '../components/Card.astro';
import SectionLabel from '../components/SectionLabel.astro';
import type { CardCta } from '../components/Card.astro';
import { ctaBlank } from '../lib/cta';

type Card = {
  title?: string;
  subtitle?: string;
  body?: string;
  phone?: string;
  cta?: { label: string; href: string };
};

type Intro = { title?: string; body: string };

type Section = {
  id: string;
  htmlId?: string; // override the rendered DOM id (defaults to `section-${id}`)
  label: string; // can contain <br> for multi-line
  colour: 'blue' | 'grey'; // .grey makes uk-card-primary render dark grey
  // split  = label top-left, intros top-right, action cards full-width below
  // compact = label left (1/2), intros + cards combined in 2-col grid right (1/2)
  layout: 'split' | 'compact';
  // For compact sections only — when true, the inner wrapper gets
  // `alternates` + colour modifier classes, which trigger the bigger
  // 46px title styling used by The Committee. Leave false for sections
  // whose compact cards are paragraph-bodied (FA Charter).
  alternates?: boolean;
  image: string;
  intro: Intro[];
  cards: Card[];
};

const sections: Section[] = [
  {
    id: 'welfare',
    label: 'Welfare and <br>Safeguarding',
    colour: 'blue',
    layout: 'split',
    image: '/images/official-info/wellfare-safeguarding.jpg',
    intro: [
      { title: 'A safe environment', body: 'We are an England Football Accredited Club and acknowledge our responsibility to safeguard the welfare of every child and young person who is entrusted to our care.' },
      { title: 'Child or young person', body: "A child or young person is anyone under the age of 18 engaged in any Club football activity. We subscribe to The Football Association's Safeguarding Policy and Procedures." },
      { title: 'Responsibility', body: "Reporting a concern about a child is everyone's responsibility. If you have any questions or concerns please contact our club Welfare Officer below." },
      { title: 'Whistle blowing', body: "Reveal and raise concerns over misconduct or malpractice. Anyone with concerns can contact The FA's safeguarding team, the police, children's social care or the NSPCC." },
    ],
    cards: [
      { title: 'Club Welfare Officer', subtitle: 'Adam Stacey', phone: '07784 692766', cta: { label: 'Email', href: 'mailto:cwo@littletonjuniorfc.com' } },
      { title: 'County Welfare Officer', subtitle: 'Mel Gill', phone: '07885 807321', cta: { label: 'Email', href: 'mailto:Melanie.Gill@HampshireFA.com' } },
      { title: 'FA Safeguarding Team', phone: '0800 169 1863', body: 'Ext 6300 or 6400', cta: { label: 'Email', href: 'mailto:safeguarding@thefa.com' } },
      { title: 'Childline', phone: '0800 1111', cta: { label: 'Visit', href: 'https://www.childline.org.uk/' } },
      { title: 'NSPCC', phone: '0808 800 5000', cta: { label: 'Visit', href: 'https://www.nspcc.org.uk/' } },
      { title: 'Safeguarding guidance', body: "The FA's safeguarding guidance that we adhere to as a club.", cta: { label: 'Download', href: '/images/downloads/Safeguarding-lets-make-football-safe-not-sorry.pdf' } },
      { title: 'Safeguarding policy', body: "The FA's safeguarding policy that we adhere to as a club.", cta: { label: 'Download', href: '/images/downloads/Littleton_JFC_Safeguarding_Children_Policy_Procedures.pdf' } },
      { title: 'Equality policy', body: "The FA's equality policy that we adhere to as a club.", cta: { label: 'Download', href: '/images/downloads/Littleton_JFC_Equality_Policy.pdf' } },
      { title: 'Anti-bullying policy', body: 'The anti-bullying policy we adhere to.', cta: { label: 'Download', href: '/images/downloads/FA-anti-bullying-policy-for-clubs.pdf' } },
      { title: 'Complaints procedure', body: "The club's official complaints procedure.", cta: { label: 'Download', href: '/images/downloads/LJFC_Complaints.pdf' } },
    ],
  },
  {
    id: 'fa-respect',
    label: 'FA Respect Codes <br>of Conduct',
    colour: 'grey',
    layout: 'split',
    image: '/images/official-info/codeconduct.jpg',
    intro: [
      { body: 'As a club, we abide by the FA Respect codes of conduct to ensure everyone has a good time on and off the pitch.' },
      { body: 'The codes ensure that we play fairly, by the rules, for the benefit of everyone, and in a positive manner, whether we are players, supporters, or coaches.' },
      { body: "There are four codes of conduct; one respect code of conduct for young players, one for spectators and parents, one for coaches, managers and club officials, and one for match officials." },
      { body: "Please download, read, and abide by these every time there is a match. Let's get behind the FA message of… We only do positive." },
    ],
    cards: [
      { title: 'Young players', body: 'FA Respect code of conduct', cta: { label: 'Download', href: '/images/downloads/FA-respect-code-of-conduct-young-players.pdf' } },
      { title: 'Spectators and parents', body: 'FA Respect code of conduct', cta: { label: 'Download', href: '/images/downloads/FA-respect-code-of-conduct-spectators-and-parents.pdf' } },
      { title: 'Coaches and club officials', body: 'FA Respect code of conduct', cta: { label: 'Download', href: '/images/downloads/FA-respect-code-of-conduct-coaches---team-managers-and-club-officials.pdf' } },
      { title: 'Match officials', body: 'FA Respect code of conduct', cta: { label: 'Download', href: '/images/downloads/FA-respect-code-of-conduct-match-officials.pdf' } },
    ],
  },
  {
    id: 'fa-charter',
    htmlId: 'charter', // matches the `#charter` selectors in custom.css
    label: 'FA Charter <br>Standard <br>Club',
    colour: 'blue',
    layout: 'compact',
    image: '/images/official-info/charterstandard.jpg',
    intro: [
      { body: 'The England Football Accreditation is awarded to clubs rigorously adjudged to be well-run and sustainable – and which prioritise child protection, quality coaching and implementation of the Respect programme.' },
      { body: 'Its goal is to raise standards in grassroots football, support the development of clubs and leagues, recognising and rewarding them for their commitment and achievements.' },
    ],
    cards: [
      { title: 'Charter standard website', body: "The FA's initiative to create the best places for people to play and enjoy football.", cta: { label: 'Visit', href: 'http://www.thefa.com/get-involved/player/clubs-leagues/fa-charter-standard-programme/leagues' } },
    ],
  },
  {
    id: 'committee',
    label: 'The Committee',
    colour: 'grey',
    layout: 'compact',
    alternates: true,
    image: '/images/official-info/committee.jpg',
    intro: [],
    cards: [
      { title: 'Chair', subtitle: 'Ethu Crorie', cta: { label: 'Email', href: 'mailto:chair@littletonjuniorfc.com' } },
      { title: 'Secretary', subtitle: 'Mike Knowles', cta: { label: 'Email', href: 'mailto:secretary@littletonjuniorfc.com' } },
      { title: 'Treasurers', subtitle: 'Stephen Porter <br>& Emilie Dumoulin', cta: { label: 'Email', href: 'mailto:treasurer@littletonjuniorfc.com' } },
      { title: 'Welfare Officer', subtitle: 'Adam Stacey', phone: '07784 692766', cta: { label: 'Email', href: 'mailto:cwo@littletonjuniorfc.com' } },
    ],
  },
];
---

<BaseLayout title="Official Info | Littleton Junior FC" active="official-info">
  <Hero variant="image" image="/images/heros/official-info-hero.jpg" title="Official<br>Info" />

  {
    sections.map((section) => {
      // Convert a Card data entry into Card props.
      const cardCta = (card: Card): CardCta | undefined =>
        card.cta && {
          label: card.cta.label,
          href: card.cta.href,
          blank: ctaBlank(card.cta.label),
        };

      const compactWrap = [
        'offinfo4x4',
        section.alternates && 'alternates',
        section.alternates && section.colour,
        'uk-margin',
      ]
        .filter(Boolean)
        .join(' ');

      const introPadCount =
        section.layout === 'compact'
          ? (2 - ((section.intro.length + section.cards.length) % 2)) % 2
          : 0;
      const actionPadCount =
        section.layout === 'split' ? (4 - (section.cards.length % 4)) % 4 : 0;

      return (
        <Section id={section.htmlId ?? `section-${section.id}`} class={section.colour} noGrid>
          <div class="uk-grid-margin" uk-grid>
            <div class="uk-width-expand@m">
              <SectionLabel variant="wellsafeimg" title={section.label} image={section.image} />
            </div>

            {/* Split layout: intro cards in their own column */}
            {section.layout === 'split' && section.intro.length > 0 && (
              <div class="uk-width-expand@m">
                <CardGrid wrap="offinfo4x4 uk-margin" grid="uk-child-width-1-2">
                  {section.intro.map((p) => (
                    <Card title={p.title} body={p.body} />
                  ))}
                </CardGrid>
              </div>
            )}

            {/* Compact layout: intro + action cards combined, 2-col grid */}
            {section.layout === 'compact' && (
              <div class="uk-width-expand@m">
                <CardGrid wrap={compactWrap} grid="uk-child-width-1-2">
                  {section.intro.map((p) => (
                    <Card title={p.title} body={p.body} />
                  ))}
                  {section.cards.map((card) => (
                    <Card
                      dataTag={card.cta?.label}
                      title={card.title}
                      subtitle={card.subtitle}
                      phone={card.phone}
                      body={card.body}
                      cta={cardCta(card)}
                    />
                  ))}
                  {Array.from({ length: introPadCount }).map(() => (
                    <Card />
                  ))}
                </CardGrid>
              </div>
            )}
          </div>

          {/* Split layout only: full-width action cards row */}
          {section.layout === 'split' && (
            <CardGrid
              wrap={`alternates first ${section.colour} uk-margin uk-text-left`}
              grid="uk-child-width-1-2 uk-child-width-1-4@m"
            >
              {section.cards.map((card) => (
                <Card
                  dataTag={card.cta?.label}
                  title={card.title}
                  subtitle={card.subtitle}
                  phone={card.phone}
                  body={card.body}
                  cta={cardCta(card)}
                />
              ))}
              {Array.from({ length: actionPadCount }).map(() => (
                <Card />
              ))}
            </CardGrid>
          )}
        </Section>
      );
    })
  }
</BaseLayout>
