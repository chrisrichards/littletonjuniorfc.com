---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

type Card = {
  title?: string;
  subtitle?: string;
  body?: string;
  phone?: string;
  cta?: { label: string; href: string };
};

type Section = {
  id: string;
  label: string;
  colour: 'grey' | 'blue';
  image?: string;
  intro: string[];
  cards: Card[];
};

const sections: Section[] = [
  {
    id: 'welfare',
    label: 'Welfare and Safeguarding',
    colour: 'grey',
    image: '/images/official-info/wellfare-safeguarding.jpg',
    intro: [
      'We are an England Football Accredited Club and acknowledge our responsibility to safeguard the welfare of every child and young person who is entrusted to our care.',
      "A child or young person is anyone under the age of 18 engaged in any Club football activity. We subscribe to The Football Association's Safeguarding Policy and Procedures.",
      "Reporting a concern about a child is everyone's responsibility. If you have any questions or concerns please contact our club Welfare Officer below.",
      "Reveal and raise concerns over misconduct or malpractice. Anyone with concerns can contact The FA's safeguarding team, the police, children's social care or the NSPCC.",
    ],
    cards: [
      { title: 'Club Welfare Officer', subtitle: 'Adam Stacey', phone: '07784 692766', cta: { label: 'Email', href: 'mailto:cwo@littletonjuniorfc.com' } },
      { title: 'County Welfare Officer', subtitle: 'Mel Gill', phone: '07885 807321', cta: { label: 'Email', href: 'mailto:Melanie.Gill@HampshireFA.com' } },
      { title: 'FA Safeguarding Team', phone: '0800 169 1863', body: 'Ext 6300 or 6400', cta: { label: 'Email', href: 'mailto:safeguarding@thefa.com' } },
      { title: 'Childline', phone: '0800 1111', cta: { label: 'Visit', href: 'https://www.childline.org.uk/' } },
      { title: 'NSPCC', phone: '0808 800 5000', cta: { label: 'Visit', href: 'https://www.nspcc.org.uk/' } },
      { title: 'Safeguarding guidance', body: "The FA's safeguarding guidance that we adhere to as a club.", cta: { label: 'Download', href: '/images/downloads/Safeguarding-lets-make-football-safe-not-sorry.pdf' } },
      { title: 'Safeguarding policy', body: "The FA's safeguarding policy that we adhere to as a club.", cta: { label: 'Download', href: '/images/downloads/Littleton_JFC_Safeguarding_Children_Policy_Procedures.pdf' } },
      { title: 'Equality policy', body: "The FA's equality policy that we adhere to as a club.", cta: { label: 'Download', href: '/images/downloads/Littleton_JFC_Equality_Policy.pdf' } },
      { title: 'Anti-bullying policy', body: 'The anti-bullying policy we adhere to.', cta: { label: 'Download', href: '/images/downloads/FA-anti-bullying-policy-for-clubs.pdf' } },
      { title: 'Complaints procedure', body: "The club's official complaints procedure.", cta: { label: 'Download', href: '/images/downloads/LJFC_Complaints.pdf' } },
    ],
  },
  {
    id: 'fa-respect',
    label: 'FA Respect Codes of Conduct',
    colour: 'blue',
    image: '/images/official-info/codeconduct.jpg',
    intro: [
      'As a club, we abide by the FA Respect codes of conduct to ensure everyone has a good time on and off the pitch.',
      'The codes ensure that we play fairly, by the rules, for the benefit of everyone, and in a positive manner, whether we are players, supporters, or coaches.',
      "There are four codes of conduct; one respect code of conduct for young players, one for spectators and parents, one for coaches, managers and club officials, and one for match officials.",
      "Please download, read, and abide by these every time there is a match. Let's get behind the FA message of… We only do positive.",
    ],
    cards: [
      { title: 'Young players', body: 'FA Respect code of conduct', cta: { label: 'Download', href: '/images/downloads/FA-respect-code-of-conduct-young-players.pdf' } },
      { title: 'Spectators and parents', body: 'FA Respect code of conduct', cta: { label: 'Download', href: '/images/downloads/FA-respect-code-of-conduct-spectators-and-parents.pdf' } },
      { title: 'Coaches and club officials', body: 'FA Respect code of conduct', cta: { label: 'Download', href: '/images/downloads/FA-respect-code-of-conduct-coaches---team-managers-and-club-officials.pdf' } },
      { title: 'Match officials', body: 'FA Respect code of conduct', cta: { label: 'Download', href: '/images/downloads/FA-respect-code-of-conduct-match-officials.pdf' } },
    ],
  },
  {
    id: 'fa-charter',
    label: 'FA Charter Standard Club',
    colour: 'grey',
    image: '/images/official-info/charterstandard.jpg',
    intro: [
      'The England Football Accreditation is awarded to clubs rigorously adjudged to be well-run and sustainable – and which prioritise child protection, quality coaching and implementation of the Respect programme.',
      'Its goal is to raise standards in grassroots football, support the development of clubs and leagues, recognising and rewarding them for their commitment and achievements.',
    ],
    cards: [
      { title: 'Charter standard website', body: "The FA's initiative to create the best places for people to play and enjoy football.", cta: { label: 'Visit', href: 'http://www.thefa.com/get-involved/player/clubs-leagues/fa-charter-standard-programme/leagues' } },
    ],
  },
  {
    id: 'committee',
    label: 'The Committee',
    colour: 'blue',
    image: '/images/official-info/committee.jpg',
    intro: [],
    cards: [
      { title: 'Chair', subtitle: 'Ethu Crorie', cta: { label: 'Email', href: 'mailto:chair@littletonjuniorfc.com' } },
      { title: 'Secretary', subtitle: 'Mike Knowles', cta: { label: 'Email', href: 'mailto:secretary@littletonjuniorfc.com' } },
      { title: 'Treasurers', subtitle: 'Stephen Porter & Emilie Dumoulin', cta: { label: 'Email', href: 'mailto:treasurer@littletonjuniorfc.com' } },
      { title: 'Welfare Officer', subtitle: 'Adam Stacey', phone: '07784 692766', cta: { label: 'Email', href: 'mailto:cwo@littletonjuniorfc.com' } },
    ],
  },
];
---

<BaseLayout title="Official Info | Littleton Junior FC" active="official-info">
  <Hero variant="image" image="/images/heros/official-info-hero.jpg" title="Official<br>Info" />

  {
    sections.map((section) => (
      <div class="uk-section-default uk-section">
        <div class="uk-container">
          <div class="uk-grid-margin" uk-grid>
            {/* Section label */}
            <div class="uk-width-expand@m">
              <div class:list={[section.colour === 'blue' ? 'bluesquare' : 'greysquare', 'uk-margin']}>
                <div class="uk-child-width-1-1 uk-grid-match" uk-grid>
                  <div>
                    <div class="el-item uk-panel uk-margin-remove-first-child">
                      <h3 class="el-title">{section.label}</h3>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            {/* Intro paragraphs as cards */}
            {section.intro.length > 0 && (
              <div class="uk-width-expand@m">
                <div
                  class:list={[
                    'offinfo4x4',
                    'alternates',
                    section.colour === 'blue' ? 'grey' : 'blue',
                    'uk-margin',
                  ]}
                >
                  <div class="uk-child-width-1-2 uk-grid-match" uk-grid>
                    {section.intro.map((p) => (
                      <div>
                        <div
                          class:list={[
                            'el-item',
                            'uk-card',
                            section.colour === 'blue' ? 'uk-card-secondary' : 'uk-card-primary',
                            'uk-card-body',
                            'uk-margin-remove-first-child',
                          ]}
                        >
                          <div class="el-content uk-panel uk-margin-top">
                            <p>{p}</p>
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            )}
          </div>

          {/* Action cards */}
          <div
            class:list={[
              'offinfo4x4',
              'alternates',
              section.colour === 'blue' ? 'grey' : 'blue',
              'uk-margin',
            ]}
          >
            <div class="uk-child-width-1-2 uk-child-width-1-4@m uk-grid-match" uk-grid>
              {section.cards.map((card) => (
                <div data-tag={card.cta?.label}>
                  <div
                    class:list={[
                      'el-item',
                      'uk-card',
                      section.colour === 'blue' ? 'uk-card-secondary' : 'uk-card-primary',
                      'uk-card-body',
                      'uk-margin-remove-first-child',
                    ]}
                  >
                    <div class="el-content uk-panel uk-margin-top">
                      {card.title && <h3>{card.title}</h3>}
                      {card.subtitle && <h4>{card.subtitle}</h4>}
                      {card.phone && <p>{card.phone}</p>}
                      {card.body && <p>{card.body}</p>}
                    </div>
                    {card.cta && (
                      <div class="uk-margin-top">
                        <a
                          href={card.cta.href}
                          class="el-link uk-button uk-button-default"
                          {...(card.cta.label !== 'Email' &&
                            card.cta.label !== 'Download' && {
                              target: '_blank',
                              rel: 'noopener',
                            })}
                        >
                          {card.cta.label}
                        </a>
                      </div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    ))
  }
</BaseLayout>
