---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';
import { chunk } from '../lib/chunk';

const teams = await getCollection('teams');
teams.sort((a, b) => a.data.order - b.data.order);

// Group ages into 4 quartiles of 4 to mirror the Joomla nav rows
// (#u6-9, #u10-13, #u14-17, #u18-pan). Each row is padded to 4 cards.
const rowClasses = ['first', 'second', 'third', 'fourth'] as const;
const rowIds = ['u6-9', 'u10-13', 'u14-17', 'u18-pan'] as const;

const navRows = chunk(teams, 4).map((slice, i) => ({
  id: rowIds[i],
  cls: rowClasses[i],
  teams: slice,
  padCount: Math.max(0, 4 - slice.length),
}));
---

<BaseLayout title="Teams | Littleton Junior FC" active="teams">
  <Hero variant="image" image="/images/heros/teams.jpg" title="Teams" />

  {
    navRows.map((row, idx) => (
      <>
        {/* Age-group nav row: 4 cards, click "More" to slide open the panel */}
        <div id={`alternates${idx + 1}`} class="uk-section-default uk-section">
          <div class="uk-container">
            <div class="uk-grid-margin" uk-grid>
              <div class="uk-width-1-1@m">
                <div
                  id={row.id}
                  class:list={['alternates', row.cls, 'uk-margin', 'uk-text-left']}
                >
                  <div class="uk-child-width-1-4 uk-grid-match" uk-grid>
                    {row.teams.map((t) => (
                      <Card
                        heading={t.data.age}
                        body={t.data.yearLabel.replace(' / ', '<br>')}
                        cta={{
                          label: 'More',
                          href: `#${t.data.id}`,
                          attrs: { 'data-panel-target': t.data.id },
                        }}
                      />
                    ))}
                    {Array.from({ length: row.padCount }).map(() => (
                      <Card />
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* Hidden squad-detail panels for each age in this nav row */}
        {row.teams.map((t) => (
          <div id={t.data.id} class="hiddenbox uk-section-default uk-section">
            <div class="uk-container">
              <div class="info uk-grid-margin" uk-grid>
                <div class="uk-width-1-1@m">
                  {t.data.squads.map((s) => (
                    <div class="uk-margin">
                      <div class="uk-child-width-1-1 uk-child-width-1-4@m uk-grid-match" uk-grid>
                        <Card heading={s.name} />
                        <Card
                          contentLabel="Contact"
                          phone={s.managerName}
                          cta={{ label: 'Email', href: `mailto:${s.managerEmail}` }}
                        />
                        <Card />
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </>
    ))
  }

  <div class="quoteimage uk-section-default uk-section">
    <div class="uk-container">
      <div class="uk-grid-margin" uk-grid>
        <div class="uk-width-1-1@m">
          <div class="uk-margin">
            <img
              class="el-image"
              src="/images/teams/teams-bottom.jpg"
              alt=""
              width="2400"
              height="1134"
              loading="lazy"
            />
          </div>
          <blockquote class="quotes">
            <span>&ldquo;</span>Joe is loving his football and has made loads of new friends at the club.<span>&rdquo;</span>
          </blockquote>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      var DURATION = 400;
      var openPanel = null;
      var animating = false;

      function slideDown(el, done) {
        el.style.display = 'block';
        el.style.overflow = 'hidden';
        el.style.height = '0px';
        var target = el.scrollHeight;
        el.getBoundingClientRect();
        el.style.transition = 'height ' + DURATION + 'ms ease';
        requestAnimationFrame(function () {
          el.style.height = target + 'px';
        });
        var onEnd = function (e) {
          if (e.target !== el || e.propertyName !== 'height') return;
          el.removeEventListener('transitionend', onEnd);
          el.style.height = '';
          el.style.overflow = '';
          el.style.transition = '';
          if (done) done();
        };
        el.addEventListener('transitionend', onEnd);
      }

      function slideUp(el, done) {
        el.style.overflow = 'hidden';
        el.style.height = el.scrollHeight + 'px';
        el.getBoundingClientRect();
        el.style.transition = 'height ' + DURATION + 'ms ease';
        requestAnimationFrame(function () {
          el.style.height = '0px';
        });
        var onEnd = function (e) {
          if (e.target !== el || e.propertyName !== 'height') return;
          el.removeEventListener('transitionend', onEnd);
          el.style.display = '';
          el.style.height = '';
          el.style.overflow = '';
          el.style.transition = '';
          if (done) done();
        };
        el.addEventListener('transitionend', onEnd);
      }

      function addCloseButton(panel) {
        if (panel.querySelector('.closeMe')) return;
        var btn = document.createElement('a');
        btn.className = 'closeMe';
        btn.href = '#';
        btn.setAttribute('aria-label', 'Close');
        btn.addEventListener('click', function (e) {
          e.preventDefault();
          closePanel();
        });
        panel.appendChild(btn);
      }

      function closePanel(done) {
        if (!openPanel || animating) return;
        var panel = openPanel;
        openPanel = null;
        animating = true;
        slideUp(panel, function () {
          var x = panel.querySelector('.closeMe');
          if (x) x.remove();
          animating = false;
          if (done) done();
        });
      }

      function openPanelEl(panel) {
        if (animating) return;
        if (openPanel === panel) {
          closePanel();
          return;
        }
        var go = function () {
          animating = true;
          slideDown(panel, function () {
            addCloseButton(panel);
            openPanel = panel;
            animating = false;
          });
        };
        if (openPanel) closePanel(go);
        else go();
      }

      document.querySelectorAll('a[data-panel-target]').forEach(function (a) {
        a.addEventListener('click', function (e) {
          e.preventDefault();
          var id = a.getAttribute('data-panel-target');
          var panel = document.getElementById(id);
          if (panel) openPanelEl(panel);
        });
      });

      if (window.location.hash) {
        var target = document.getElementById(window.location.hash.slice(1));
        if (target && target.classList.contains('hiddenbox')) openPanelEl(target);
      }
    })();
  </script>
</BaseLayout>
