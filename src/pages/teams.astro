---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const teams = await getCollection('teams');
teams.sort((a, b) => a.data.order - b.data.order);

// Chunk into rows of 4 for the navigation grid (matches the live 4-col layout).
function chunk<T>(arr: T[], size: number): T[][] {
  const out: T[][] = [];
  for (let i = 0; i < arr.length; i += size) out.push(arr.slice(i, i + size));
  return out;
}

const navRows = chunk(teams, 4);
---

<BaseLayout title="Teams | Littleton Junior FC" active="teams">
  <Hero variant="image" image="/images/heros/teams.jpg" title="Teams" />

  <div class="contactus">
    {/* Age-group navigation — clicking MORE scrolls to that age's squad section */}
    {
      navRows.map((row, rowIdx) => (
        <div class="uk-section-default uk-section">
          <div class="uk-container">
            <div class="uk-grid-margin" uk-grid>
              <div class="uk-width-1-1@m">
                <div
                  class:list={[
                    'alternates',
                    rowIdx % 2 === 0 ? 'first' : 'second',
                    'contacts',
                    'uk-margin',
                    'uk-text-left',
                  ]}
                >
                  <div class="js-filter uk-child-width-1-2 uk-child-width-1-4@m uk-grid-match" uk-grid>
                    {row.map((t) => (
                      <div>
                        <div class="el-item uk-card uk-card-primary uk-card-body uk-margin-remove-first-child">
                          <div class="el-content uk-panel uk-margin-top">
                            <h2>{t.data.age}</h2>
                            <p>{t.data.yearLabel}</p>
                          </div>
                          <div class="uk-margin-top">
                            <a
                              href={`#squads-${t.data.id}`}
                              class="el-link uk-button uk-button-default"
                            >
                              More
                            </a>
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))
    }

    {/* Per-age squad detail sections */}
    {
      teams.map((t) => (
        <div id={`squads-${t.data.id}`} class="uk-section-default uk-section">
          <div class="uk-container">
            <div class="info uk-grid-margin" uk-grid>
              <div class="uk-width-1-1@m">
                <div
                  class:list={['alternates', 'second', 'contacts', 'uk-margin', 'uk-text-left']}
                >
                  <div class="uk-child-width-1-2 uk-child-width-1-4@m uk-grid-match" uk-grid>
                    {/* Header card with the age label */}
                    <div>
                      <div class="el-item uk-card uk-card-primary uk-card-body uk-margin-remove-first-child">
                        <div class="el-content uk-panel uk-margin-top">
                          <h2>{t.data.age}</h2>
                          <p>{t.data.yearLabel}</p>
                        </div>
                      </div>
                    </div>

                    {/* Squads in this age group */}
                    {t.data.squads.map((s) => (
                      <div>
                        <div class="el-item uk-card uk-card-primary uk-card-body uk-margin-remove-first-child">
                          <div class="el-content uk-panel uk-margin-top">
                            <h2>{s.name}</h2>
                            <h4>Contact</h4>
                            <p>{s.managerName}</p>
                          </div>
                          <div class="uk-margin-top">
                            <a
                              href={`mailto:${s.managerEmail}`}
                              class="el-link uk-button uk-button-default"
                            >
                              Email
                            </a>
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</BaseLayout>
