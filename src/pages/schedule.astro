---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout
  title="Pitch Bookings | Littleton Junior FC"
  description="The Littleton Junior FC pitch booking system is being rebuilt."
>
  <Hero variant="image" image="/images/heros/teams.jpg" title="Pitch<br>Bookings" />

  <div class="privacy uk-margin">
    <h5>Pitch booking system coming soon</h5>
    <p>
      We're rebuilding the pitch booking system as part of the new club website. Until it's
      ready, coaches can book Littleton Rec by contacting the relevant Age Group Coordinator
      listed on the <a href="/contact-us">Contact us</a> page.
    </p>
    <p>For guidance on other pitches (KGV, Garrison Ground), see <a href="/resources">Resources</a>.</p>
  </div>
</BaseLayout>
