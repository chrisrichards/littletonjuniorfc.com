---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const entry = await getEntry('pages', 'privacy-policy');
if (!entry) throw new Error('Missing pages/privacy-policy entry');
const { Content } = await render(entry);
const { title, headerText, description } = entry.data;
---

<BaseLayout title={`${title} | Littleton Junior FC`} description={description}>
  <Hero variant="banner" title={headerText ?? title} />

  <div class="privacy uk-margin">
    <Content />
  </div>
</BaseLayout>
