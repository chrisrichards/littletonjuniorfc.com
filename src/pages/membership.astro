---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import CardGrid from '../components/CardGrid.astro';
import Card from '../components/Card.astro';
import SectionLabel from '../components/SectionLabel.astro';
import site from '../content/settings/site.json';

const cards = [
  {
    title: 'Our Subs',
    body: `Club fees for ${site.fees.season} are £${site.fees.full} for full members who play league matches, and £${site.fees.trainingOnly} for those who only train. This pays for Saints Foundation coaches, pitch hire, equipment, kit, and other costs.`,
  },
  {
    title: 'Joining us',
    body: 'If you are looking to join the club, please contact the relevant Age Group Coordinator listed on the <em>Contact us</em> page.',
  },
  {
    title: 'Paying Subs',
    body: 'To pay your annual subs, please log into our Pitchero membership system.',
    cta: {
      label: 'Pay subs',
      href: 'https://www.pitchero.com/clubs/littletonjuniorfc/payments',
      blank: true,
    },
    tag: 'PAY-SUBS',
  },
  {
    title: 'Your details',
    body: 'To make any changes to your account, please log into our Pitchero membership system.',
    cta: {
      label: 'See your details',
      href: 'https://pitchero.com/clubs/littletonjuniorfc',
      blank: true,
    },
    tag: 'See-Your-Details',
  },
];
---

<BaseLayout title="Membership | Littleton Junior FC" active="membership">
  <Hero variant="image" image="/images/heros/membership-hero.jpg" title="Membership" />

  <Section class="grey">
    <div class="uk-width-expand@m">
      <SectionLabel variant="wellsafeimg" image="/images/membership/membershipblock.jpg" />
    </div>

    <div class="uk-width-expand@m">
      <CardGrid id="membership" wrap="offinfo4x4 alt membership uk-margin" grid="uk-child-width-1-2">
        {
          cards.map((card) => (
            <Card title={card.title} body={card.body} cta={card.cta} dataTag={card.tag} />
          ))
        }
      </CardGrid>
    </div>
  </Section>
</BaseLayout>
