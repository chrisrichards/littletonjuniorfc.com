---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import site from '../content/settings/site.json';

const cards = [
  {
    title: 'Our Subs',
    body: `Club fees for ${site.fees.season} are £${site.fees.full} for full members who play league matches, and £${site.fees.trainingOnly} for those who only train. This pays for Saints Foundation coaches, pitch hire, equipment, kit, and other costs.`,
  },
  {
    title: 'Joining us',
    body: 'If you are looking to join the club, please contact the relevant Age Group Coordinator listed on the <em>Contact us</em> page.',
  },
  {
    title: 'Paying Subs',
    body: 'To pay your annual subs, please log into our Pitchero membership system.',
    cta: { label: 'Read more', href: 'https://www.pitchero.com/clubs/littletonjuniorfc/payments' },
    tag: 'PAY-SUBS',
  },
  {
    title: 'Your details',
    body: 'To make any changes to your account, please log into our Pitchero membership system.',
    cta: { label: 'Read more', href: 'https://pitchero.com/clubs/littletonjuniorfc' },
    tag: 'See-Your-Details',
  },
];
---

<BaseLayout title="Membership | Littleton Junior FC" active="membership">
  <Hero
    variant="image"
    image="/images/heros/membership-hero.jpg"
    title="Membership"
  />

  <div class="grey uk-section-default uk-section">
    <div class="uk-container">
      <div class="uk-grid-margin" uk-grid>
        <div class="uk-width-expand@m">
          <div class="wellsafeimg uk-margin">
            <div class="uk-child-width-1-1 uk-grid-match" uk-grid>
              <div>
                <div class="el-item uk-panel uk-margin-remove-first-child">
                  <img
                    class="el-image"
                    alt=""
                    data-src="/images/membership/membershipblock.jpg"
                    data-width="1240"
                    data-height="1240"
                    uk-img
                  />
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="uk-width-expand@m">
          <div id="membership" class="offinfo4x4 alt membership uk-margin">
            <div class="uk-child-width-1-2 uk-grid-match" uk-grid>
              {
                cards.map((card) => (
                  <div data-tag={card.tag}>
                    <div class="el-item uk-card uk-card-secondary uk-card-body uk-margin-remove-first-child">
                      <div class="el-content uk-panel uk-margin-top">
                        <h3>{card.title}</h3>
                        <p set:html={card.body} />
                      </div>
                      {card.cta && (
                        <div class="uk-margin-top">
                          <a
                            href={card.cta.href}
                            target="_blank"
                            rel="noopener"
                            class="el-link uk-button uk-button-default"
                          >
                            {card.cta.label}
                          </a>
                        </div>
                      )}
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
