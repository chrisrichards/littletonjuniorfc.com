---
/**
 * Hero band for inner pages.
 *
 * Variants:
 *   - "image"  — full-bleed image with optional title overlay (default for inner pages)
 *   - "banner" — 300px dark-grey bar with title overlay (privacy + terms only)
 *   - "plain"  — full-bleed image, no overlay (home)
 *
 * The hero uses a -246px top margin to tuck under the fixed-height header,
 * matching the live YOOtheme layout.
 */
interface Props {
  image?: string;
  title?: string;
  variant?: 'image' | 'banner' | 'plain';
  /** Optional responsive overrides — the home banner ships a srcset and its
   *  own intrinsic dimensions; inner-page heroes use the 2400×1701 defaults. */
  srcset?: string;
  sizes?: string;
  width?: number | string;
  height?: number | string;
}

const {
  image,
  title,
  variant = 'image',
  srcset,
  sizes,
  width = 2400,
  height = 1701,
} = Astro.props;
---

<div
  id="hero"
  data-variant={variant}
  class:list={[
    'hero',
    'uk-section-default',
    'uk-section',
    'uk-padding-remove-top',
    'uk-padding-remove-bottom',
    { privacysect: variant === 'banner' },
  ]}
>
  <div class="uk-margin-remove-vertical" uk-grid>
    <div class="uk-width-1-1@m">
      <div id="hero-bg" class="uk-margin-remove-vertical">
        {
          image && (
            <img
              class="el-image"
              alt=""
              data-src={image}
              data-srcset={srcset}
              data-sizes={sizes}
              data-width={width}
              data-height={height}
              uk-img
            />
          )
        }
      </div>
      {title && variant !== 'plain' && <h1 class="headerText" set:html={title} />}
    </div>
  </div>
</div>
