---
/**
 * Section label panel used by official-info and resources. Three variants
 * keyed off the original Joomla page classes:
 *
 *   - wellsafeimg: image with title overlaid top-left (official-info)
 *   - bluesquare:  blue panel with title overlaid top-left (resources)
 *   - greysquare:  dark grey panel with title overlaid top-left (resources)
 *
 * All three rely on existing CSS in custom.css + overrides.css to position
 * the title absolutely.
 */
import { Picture } from 'astro:assets';
import { asset } from '../lib/images';

export interface Props {
  /** Optional — set:html so callers can pass <br>. wellsafeimg with no
   *  title is valid (membership uses an image-only panel). */
  title?: string;
  variant: 'wellsafeimg' | 'bluesquare' | 'greysquare';
  image?: string; // only used by wellsafeimg
}

const { title, variant, image } = Astro.props;
const src = variant === 'wellsafeimg' && image ? asset(image) : null;
---

<div class:list={[variant, 'uk-margin']}>
  <div class="uk-child-width-1-1 uk-grid-match" uk-grid>
    <div>
      <div class="el-item uk-panel uk-margin-remove-first-child">
        {
          src && (
            <Picture
              src={src}
              formats={['avif', 'webp']}
              widths={[400, 640, 800]}
              sizes="(min-width: 960px) 50vw, 100vw"
              alt=""
              loading="lazy"
              class="el-image"
            />
          )
        }
        {title && <h3 class="el-title uk-margin-top uk-margin-remove-bottom" set:html={title} />}
      </div>
    </div>
  </div>
</div>
